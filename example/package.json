{
  "name": "svelte-example",
  "version": "1.0.0",
  "private": true,
  "description": "使用 Svelte 5 开发小程序",
  "templateInfo": {
    "name": "default",
    "typescript": false,
    "css": "none"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp --no-check",
    "build:h5": "taro build --type h5 --no-check",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.24.4",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "svelte": "5.55.5",
    "tarojs-plugin-svelte": "file:.."
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@tarojs/cli": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "babel-preset-taro": "4.2.0",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.2.0",
    "postcss": "^8.5.6",
    "stylelint": "^16.4.0",
    "webpack": "5.91.0"
  }
}
